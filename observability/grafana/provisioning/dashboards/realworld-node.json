      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(http_requests_total{job=\"realworld-node\", status=~\"2..\"})",
          "legendFormat": "Sucesso",
          "refId": "A"
        }
      ],
      "title": "Total de Requisicoes com Sucesso",
      "description": "Total de requisicoes bem-sucedidas (status 2xx).",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
