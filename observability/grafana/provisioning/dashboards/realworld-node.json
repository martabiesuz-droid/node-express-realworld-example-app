      "id": 2,
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"realworld-node\"}[1m]))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "title": "Tempo de Resposta por Endpoint (segundos)",
      "description": "Mostra o tempo que a API leva para responder. Valores acima de 1s indicam lentidao.",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
"fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
