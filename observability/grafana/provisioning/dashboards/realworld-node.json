          "refId": "A"
        }
      ],
      "title": "Requests por Endpoint (por segundo)",
      "description": "Mostra quantas requisicoes por segundo cada endpoint esta recebendo.",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" }, "overrides": [] },
