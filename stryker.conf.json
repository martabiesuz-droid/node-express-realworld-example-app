{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "testRunner": "command",
  "mutate": [
    "src/app/**/*.ts",
    "!src/app/**/*.spec.ts",
    "!src/app/**/*.test.ts"
  ],
  "reporters": [
    "html",
    "clear-text",
    "progress"
  ],
  "htmlReporter": {
    "fileName": "reports/mutation/index.html"
  },
  "thresholds": {
    "high": 95,
    "low": 60,
    "break": null
  },
  "concurrency": 2,
  "timeoutMS": 60000,
  "commandRunner": {
    "command": "npx jest"
  },
  "coverageAnalysis": "off"
}